# Persistent Reasoning Engine — environment variables
# Copy this file to .env and fill in real values. .env is gitignored.

# --- Postgres ---
# Local docker-compose default:
# DATABASE_URL=postgresql://reasoning:test@localhost:5432/reasoning
# Inside the compose network the app reaches the DB as 'db' on port 5432:
DATABASE_URL=postgresql://reasoning:test@localhost:5432/reasoning

# --- LLM providers (raw SDKs; no LangChain / LlamaIndex) ---
# At least one is required for extraction; both are wired so we can route per-document.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# --- SEC EDGAR ---
# SEC requires a real contact email in the User-Agent header of every request.
# Use an address you monitor — SEC throttles or blocks calls without one.
EDGAR_CONTACT_EMAIL=you@example.com